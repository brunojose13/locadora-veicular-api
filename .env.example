APP_NAME=Car-Rental-API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Para rodar com Docker, use DB_HOST=car-rental-mysql (nome do serviço no docker-compose).
# Para rodar o PHP localmente, comente DB_HOST e use 127.0.0.1 com a porta exposta (3310).

DB_CONNECTION=mysql
DB_HOST=car-rental-mysql
DB_PORT=3306
DB_DATABASE=
DB_DATABASE_TEST=
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# AUTH_TOKEN_EXPIRATION_MINUTES=

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
